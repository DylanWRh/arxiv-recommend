# App behavior
RESEARCH_PROFILE=I am a researcher focused on 3D modeling and 3D vision, including understanding, generation, editing, and reconstruction. My work sits at the intersection of computer graphics, large language models, and agent systems, with an emphasis on combining LLM- and agent-driven reasoning with 3D vision workflows.
APP_TIMEZONE=Asia/Shanghai
EMAIL_TO=you@example.com
OUTPUT_PATH=./reports

# LLM settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
TIME_PARSE_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_BATCH_SIZE=40
LLM_TIMEOUT=60

# SMTP settings
# Defaulted from the official PKU ITS guide for @stu.pku.edu.cn client access.
# The guide specifies smtp.stu.pku.edu.cn plus authenticated sending with campus account credentials.
# It does not list a submission port, so this example uses authenticated TLS on 587.
SMTP_HOST=smtp.stu.pku.edu.cn
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-campus-account
SMTP_PASS=your-campus-password
EMAIL_FROM=your-id@stu.pku.edu.cn


