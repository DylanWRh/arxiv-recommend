# App behavior
RESEARCH_PROFILE=I am a researcher focused on 3D modeling and 3D vision, including understanding, generation, editing, and reconstruction. My work sits at the intersection of computer graphics, large language models, and agent systems, with an emphasis on combining LLM- and agent-driven reasoning with 3D vision workflows.
APP_TIMEZONE=Asia/Shanghai
SAVE_REPORT=true
SEND_EMAIL=false
SAVE_TO_DB=true
EMAIL_TO=you@example.com
OUTPUT_PATH=./reports
RECOMMENDATIONS_DB_PATH=./data/recommendations.db

# LLM settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
TIME_PARSE_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_BATCH_SIZE=40
LLM_TIMEOUT=60

# SMTP settings
# Defaulted for Gmail SMTP with STARTTLS.
# Use a Google App Password for SMTP_PASS, not your normal Google login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=your-gmail-address@gmail.com


