# App behavior
RESEARCH_PROFILE=I focus on 3D vision, reconstruction, and agentic multimodal systems for content generation.
APP_TIMEZONE=Asia/Shanghai
EMAIL_TO=you@example.com
OUTPUT_PATH=./reports

# LLM settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TIME_PARSE_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_BATCH_SIZE=40
LLM_TIMEOUT=60

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=your-email@example.com


